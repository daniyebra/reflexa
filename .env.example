# LLM provider — set to "mock" for local development (no API calls)
OPENAI_API_KEY=mock

# SQLite database path (relative to project root)
DATABASE_URL=sqlite+aiosqlite:///reflexa.db

# Logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Number of prior turns included in conversation history sent to LLM
MEMORY_TURNS=10

# Maximum characters allowed in a user message
MAX_MESSAGE_LENGTH=2000

# Which condition is shown to the user: "baseline" | "corrected"
DISPLAY_CONDITION=baseline

# LLM call timeout in seconds
LLM_TIMEOUT=30

# Prompt version overrides (defaults to latest if unset)
# BASELINE_PROMPT_VERSION=baseline/v1
# PIPELINE_DRAFT_PROMPT_VERSION=pipeline_draft/v1
# PIPELINE_VERIFIER_PROMPT_VERSION=pipeline_verifier/v1
# PIPELINE_CRITIC_PROMPT_VERSION=pipeline_critic/v1
# PIPELINE_REVISER_PROMPT_VERSION=pipeline_reviser/v1
# EVAL_JUDGE_PROMPT_VERSION=eval_judge/v1

# Default model for LLM calls (pipeline)
LLM_MODEL=gpt-4o-mini

# OpenRouter API key — used exclusively for judge calls during evaluation
# Get one at https://openrouter.ai
OPENROUTER_API_KEY=

# Judge models (comma-separated). Must not include LLM_MODEL to prevent self-judging.
JUDGE_MODELS=x-ai/grok-4-fast,anthropic/claude-3.5-haiku

# FastAPI host/port
API_HOST=127.0.0.1
API_PORT=8000

# Streamlit backend URL (used by ui/app.py)
BACKEND_URL=http://localhost:8000
